# =============================================================================
# WFM Control-M — Bootstrap environment only
# =============================================================================
# Runtime settings (SMTP, JWT, ports, thresholds, polling, SSH, etc.) live in
# AppConfig (SQLite). After startup, the database wins over any duplicate here.
#
# Configure tunables via: Admin → Config in the UI, or AppConfig rows in the DB.
# Bootstrap defaults are seeded by: database/dml.sql or `npm run db:seed`
# =============================================================================

# --- Required ---

# SQLite path (relative to backend/ when running locally; adjust for Docker)
DATABASE_URL="file:./dev.db"

# Encrypts secret values in AppConfig (AES-256-GCM). Required at runtime.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONFIG_ENCRYPTION_KEY=

# --- One-time database seed only (npm run db:seed) — not needed for normal runs ---

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-seed

# --- Optional: Keeper Secrets Manager bootstrap ---

# Path to ksm-config.json on disk (keep private, chmod 600). Keeper on/off is
# AppConfig key secrets.keeperEnabled — set that in Admin → Config.
KEEPER_CONFIG_FILE=

# One-time token from Keeper desktop app. Set once, start the app to bind, then
# REMOVE from .env. See backend/src/services/keeper-service.ts for setup steps.
KEEPER_ONE_TIME_TOKEN=

# --- Optional: local development ---

# SSH credential cache file (start.ps1 sets this automatically on Windows)
# SSH_CREDENTIALS_FILE=
