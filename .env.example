# Database (SQLite — file path relative to backend/)
DATABASE_URL="file:./dev.db"

# Server
PORT=4000
NODE_ENV=development

# JWT Auth
JWT_SECRET=your-secure-jwt-secret-here
JWT_EXPIRES_IN=24h

# Email Alerts (SMTP)
SMTP_HOST=smtp.yourcompany.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your-smtp-password
ALERT_FROM_EMAIL=wfm-controlm@yourcompany.com

# Slack Alerts (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# SLA Defaults
DEFAULT_SLA_WARNING_MINUTES=15
DEFAULT_SLA_CRITICAL_MINUTES=5

# WFM Integration
WFM_API_BASE_URL=https://your-wfm-instance.zebra.com/api
WFM_API_KEY=your-wfm-api-key

# DB2 (external config paths for Docker)
DB2_LIB_DIR=/config/lib
JJS_PATH=/usr/bin/jjs

# ─────────────────────────────────────────────────────────────────────────────
# Keeper Secrets Manager
# ─────────────────────────────────────────────────────────────────────────────
# Master on/off switch.
#   false (default) → passwords are read from the database (Client.db2Password)
#   true            → passwords are fetched from Keeper vault (overrides DB values)
KEEPER_ENABLED=false
# Path where ksm-config.json will be written after first-run token binding.
# Keep this file private (chmod 600). Do NOT commit it to source control.
KEEPER_CONFIG_FILE=/path/to/ksm-config.json

# One-time access token — generated in Keeper desktop app:
#   Admin Console → Secrets Manager → Applications → <your app> → Add Device → One-Time Token
# Set this ONCE to bootstrap the config file, then REMOVE it from .env.
KEEPER_ONE_TIME_TOKEN=

# DB2 client records in Keeper should use the client ID as the record title:
#   Title: CVS   Type: login   login: datareader   password: <db2pass>
# The service will look up each client by its uppercase ID (e.g. "CVS", "WAG").

# ─────────────────────────────────────────────────────────────────────────────
# Break-glass / Master Account
# Bypasses DB auth entirely and is granted ALL permissions (all 27 functions).
# Use only for emergency access when the database or admin accounts are unavailable.
# ─────────────────────────────────────────────────────────────────────────────
MASTER_USERNAME=wfmmaster

# Store a bcrypt hash, NEVER the plaintext password.
# Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('YourStrongPassword',12).then(console.log)"
MASTER_PASSWORD_HASH=$2b$12$REPLACE_WITH_REAL_HASH
